PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/inseed_hrms
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CLIENT_URL=http://localhost:3000

# DEV ONLY: set to "true" to skip Supabase JWT verification entirely and auto-login as the
# first admin (or any) Employee in the DB. Never set this to "true" outside local development.
DEV_BYPASS_AUTH=false
